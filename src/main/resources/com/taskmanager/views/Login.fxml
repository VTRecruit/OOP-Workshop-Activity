<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmanager.controller.LoginController"
      styleClass="root-pane"
      alignment="CENTER" spacing="0"
      minWidth="400" minHeight="500">

    <!-- Header -->
    <VBox styleClass="login-header" alignment="CENTER" spacing="8">
        <Label text="✔ TaskManager" styleClass="app-logo"/>
        <Label text="Sign in to your workspace" styleClass="subtitle"/>
    </VBox>

    <!-- Card -->
    <VBox styleClass="card" spacing="16" maxWidth="340">
        <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

        <Label text="Username" styleClass="field-label"/>
        <TextField fx:id="usernameField" promptText="Enter username" styleClass="text-input"/>

        <Label text="Password" styleClass="field-label"/>
        <PasswordField fx:id="passwordField" promptText="Enter password" styleClass="text-input"/>

        <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" visible="false" managed="false"/>

        <Button fx:id="loginButton" text="Sign In" onAction="#handleLogin"
                styleClass="btn-primary" maxWidth="Infinity"/>

        <Separator/>

        <HBox alignment="CENTER" spacing="6">
            <Label text="No account?" styleClass="muted"/>
            <Hyperlink text="Register here" onAction="#goToRegister" styleClass="link"/>
        </HBox>
    </VBox>

    <Label fx:id="statusLabel" styleClass="status-bar" text=""/>
</VBox>
