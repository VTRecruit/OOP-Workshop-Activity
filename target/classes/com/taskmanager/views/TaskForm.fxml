<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmanager.controller.TaskFormController"
      styleClass="root-pane" spacing="0"
      minWidth="480" minHeight="520">

    <VBox styleClass="form-header" alignment="CENTER_LEFT">
        <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
        <Label fx:id="formTitle" text="New Task" styleClass="form-title"/>
    </VBox>

    <VBox styleClass="card-flat" spacing="14" VBox.vgrow="ALWAYS">
        <padding><Insets top="20" right="28" bottom="20" left="28"/></padding>

        <Label text="Title *" styleClass="field-label"/>
        <TextField fx:id="titleField" promptText="Task title" styleClass="text-input"/>

        <Label text="Description" styleClass="field-label"/>
        <TextArea fx:id="descField" promptText="Optional description…"
                  styleClass="text-area" prefRowCount="3" wrapText="true"/>

        <HBox spacing="14">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Priority" styleClass="field-label"/>
                <ComboBox fx:id="priorityCombo" styleClass="combo-box-full" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Status" styleClass="field-label"/>
                <ComboBox fx:id="statusCombo" styleClass="combo-box-full" maxWidth="Infinity"/>
            </VBox>
        </HBox>

        <Label text="Due Date (YYYY-MM-DD)" styleClass="field-label"/>
        <TextField fx:id="dueDateField" promptText="e.g. 2025-12-31" styleClass="text-input"/>

        <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" visible="false" managed="false"/>
    </VBox>

    <HBox styleClass="form-footer" spacing="12" alignment="CENTER_RIGHT">
        <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
        <Button text="Cancel" onAction="#handleCancel" styleClass="btn-outline"/>
        <Button text="Save Task" onAction="#handleSave" styleClass="btn-primary"/>
    </HBox>
</VBox>
